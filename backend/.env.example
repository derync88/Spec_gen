# Server
PORT=4000
NODE_ENV=development

# Postgres (matches docker-compose.yml — note host port 5544)
DATABASE_URL=postgresql://specgen:specgen@localhost:5544/specgen

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS — the frontend dev origin
CORS_ORIGIN=http://localhost:5173

# AI provider: "claude" or "openai"
AI_PROVIDER=claude

# Anthropic (Claude)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
